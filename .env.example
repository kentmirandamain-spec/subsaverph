# SubSaverPH payment configuration
# Copy to .env and fill keys for providers you want.

# public site URL (Render example: https://subsaverph.onrender.com)
PUBLIC_URL=http://127.0.0.1:8790
SECRET_KEY=change-me
FORCE_HTTPS=0

# ---- Card (Stripe) ----
# https://dashboard.stripe.com/apikeys
PAYMENT_MODE=stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- GCash + Maya + GrabPay + ShopeePay (PayMongo — Philippines) ----
# https://dashboard.paymongo.com
PAYMONGO_SECRET_KEY=sk_test_...
PAYMONGO_PUBLIC_KEY=pk_test_...
# Set to 0 only for local testing without verifying payment status
PAYMONGO_REQUIRE_VERIFY=1
PAYMONGO_TRUST_RETURN=0

# ---- Xendit (PH e-wallets + cards alternative to PayMongo) ----
# https://dashboard.xendit.co
# XENDIT_SECRET_KEY=xnd_development_... or xnd_production_...
# Optional callback token (must match Dashboard → Callbacks verification token)
# XENDIT_CALLBACK_TOKEN=
# XENDIT_REQUIRE_VERIFY=1
# XENDIT_TRUST_RETURN=0
# XENDIT_INVOICE_DURATION=86400
# Which backend powers gcash/maya/grab_pay/shopeepay: auto | xendit | paymongo
# EWALLET_PROVIDER=auto

# ---- PayPal ----
# https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ---- Crypto (NOWPayments) ----
# https://account.nowpayments.io
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_API_BASE=https://api.nowpayments.io/v1
CRYPTO_TRUST_RETURN=0

# ---- Free Help chat (default: no key needed) ----
# Built-in store FAQ always works free.
# Optional free cloud LLM (smarter wording):
#   USE_CLOUD_CHAT=1
#   GEMINI_API_KEY=...   from https://aistudio.google.com/apikey
#   or GROQ_API_KEY=...  from https://console.groq.com
USE_CLOUD_CHAT=0
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional paid Grok (only if USE_CLOUD_CHAT=1 and you have credits)
# https://console.x.ai
# XAI_API_KEY=
# XAI_MODEL=grok-4.5
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_CHAT_TOOLS=0

# ---- Invoice email (codes emailed to customer after payment) ----
# Option A — Resend (recommended on Render): https://resend.com
# RESEND_API_KEY=re_...
# MAIL_FROM=SubSaverPH <onboarding@resend.dev>
# MAIL_FROM_NAME=SubSaverPH
# MAIL_REPLY_TO=you@gmail.com
# You also get a BCC copy of every order:
# ORDER_NOTIFY_EMAIL=you@gmail.com

# Option B — SMTP (Gmail app password, Outlook, SendGrid SMTP, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@gmail.com
# SMTP_TLS=1
# MAIL_FROM_NAME=SubSaverPH
# MAIL_REPLY_TO=you@gmail.com
# ORDER_NOTIFY_EMAIL=you@gmail.com
