# SubSaverPH payment configuration
# Copy to .env and fill keys for providers you want.

# public site URL (Render example: https://subsaverph.onrender.com)
PUBLIC_URL=http://127.0.0.1:8790
SECRET_KEY=change-me
FORCE_HTTPS=0

# ---- Card (Stripe) ----
# https://dashboard.stripe.com/apikeys
PAYMENT_MODE=stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- GCash + Maya + Card (PayMongo — Philippines) ----
# https://dashboard.paymongo.com
PAYMONGO_SECRET_KEY=sk_test_...
PAYMONGO_PUBLIC_KEY=pk_test_...
# Set to 0 only for local testing without verifying payment status
PAYMONGO_REQUIRE_VERIFY=1
PAYMONGO_TRUST_RETURN=0

# ---- PayPal ----
# https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ---- Crypto (NOWPayments) ----
# https://account.nowpayments.io
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_API_BASE=https://api.nowpayments.io/v1
CRYPTO_TRUST_RETURN=0

# ---- Invoice email (codes delivered to customer after payment) ----
# Option A — Resend (recommended on Render): https://resend.com
# RESEND_API_KEY=re_...
# MAIL_FROM=SubSaverPH <onboarding@resend.dev>
# MAIL_FROM_NAME=SubSaverPH
# MAIL_REPLY_TO=you@example.com

# Option B — SMTP (Gmail app password, Outlook, SendGrid SMTP, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@gmail.com
# SMTP_TLS=1
# MAIL_FROM_NAME=SubSaverPH
# MAIL_REPLY_TO=you@gmail.com
